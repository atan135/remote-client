{
  "profiles": {
    "claude_code_session": {
      "label": "Claude Code",
      "runner": "pty",
      "command": "claude",
      "argsTemplate": [],
      "cwdPolicy": "allowlist",
      "outputMode": "final_only",
      "finalOutputMarkers": {
        "start": "<<<FINAL>>>",
        "end": "<<<END_FINAL>>>"
      },
      "envAllowlist": [
        "ANTHROPIC_API_KEY",
        "HTTP_PROXY",
        "HTTPS_PROXY",
        "NO_PROXY"
      ],
      "idleTimeoutMs": 1800000
    },
    "codex_code_session": {
      "label": "Codex CLI",
      "runner": "pty",
      "command": "pwsh",
      "argsTemplate": [
        "-NoLogo",
        "-NoExit",
        "-Command",
        "[Console]::InputEncoding=[System.Text.Encoding]::UTF8; [Console]::OutputEncoding=[System.Text.Encoding]::UTF8"
      ],
      "cwdPolicy": "allowlist",
      "outputMode": "final_only",
      "finalOutputMarkers": {
        "start": "<<<FINAL>>>",
        "end": "<<<END_FINAL>>>"
      },
      "envAllowlist": [
        "OPENAI_API_KEY",
        "OPENAI_BASE_URL",
        "OPENAI_ORG_ID",
        "OPENAI_PROJECT_ID",
        "HTTP_PROXY",
        "HTTPS_PROXY",
        "NO_PROXY"
      ],
      "kind": "cli",
      "description": "Run Codex non-interactively through codex exec in a persistent PowerShell session.",
      "idleTimeoutMs": 1800000
    }
  }
}
