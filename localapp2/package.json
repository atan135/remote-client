{
  "name": "remote-localapp2",
  "version": "0.1.0",
  "private": true,
  "description": "Remote LocalApp2 Electron desktop agent",
  "author": "remote-client",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "sync:localapp": "node tools/sync-localapp-files.mjs --write",
    "check:localapp-sync": "node tools/sync-localapp-files.mjs --check",
    "verify:chain": "node tools/verify-secure-chain.mjs",
    "dev:renderer": "vite --config vite.config.js",
    "dev:electron": "wait-on tcp:5174 && cross-env LOCALAPP2_RENDERER_URL=http://127.0.0.1:5174 electron .",
    "dev": "npm run sync:localapp && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:renderer": "vite build --config vite.config.js",
    "build": "npm run sync:localapp && npm run build:renderer",
    "dist:win": "npm run sync:localapp && npm run build:renderer && electron-builder --win"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "iconv-lite": "^0.6.3",
    "log4js": "^6.9.1",
    "node-pty": "^1.1.0",
    "vue": "^3.5.13",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "30.5.1",
    "electron-builder": "^24.13.3",
    "vite": "^6.0.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.remote.localapp2",
    "productName": "Remote LocalApp2",
    "electronVersion": "30.5.1",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "config/**/*",
      "electron/**/*",
      "src/**/*",
      "shared/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
