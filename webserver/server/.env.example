HTTP_PORT=3100
AGENT_SHARED_TOKEN=
COMMAND_HISTORY_LIMIT=100
TERMINAL_SESSION_HISTORY_LIMIT=100
TERMINAL_SESSION_OUTPUT_LIMIT=200
TERMINAL_SESSION_PERSIST_DEBOUNCE_MS=500
TERMINAL_SESSION_TURN_SYNC_DEBOUNCE_MS=1000
AGENT_HEARTBEAT_BROADCAST_INTERVAL_MS=30000
SECURE_COMMAND_TTL_MS=60000
# 可选：all / trace / debug / info / warn / error / fatal / mark / off
LOG_LEVEL=info
LOG_DIR=logs
MYSQL_URL=mysql://root:atan135@127.0.0.1:3306/remote_client
CAN_JIETU=false
# 可选：开发环境可指向 Vite 前端，例如 http://127.0.0.1:5173；生产环境留空则截 server 托管的前端。
JIETU_WEB_BASE_URL=
JIETU_OUTPUT_DIR=../output/image
JIETU_DEFAULT_WIDTH=1440
JIETU_DEFAULT_HEIGHT=1000
JIETU_MAX_WAIT_MS=12000
JIETU_SETTLE_MS=500
JIETU_MAX_CONCURRENT=1
# 可选：如果 Playwright Chromium 未安装，可指定本机浏览器路径或 channel（chrome/msedge）。
JIETU_BROWSER_EXECUTABLE_PATH=
JIETU_BROWSER_CHANNEL=
SESSION_COOKIE_NAME=remote_client_session
SESSION_TTL_HOURS=24
SESSION_SECURE=false
ALLOW_PUBLIC_REGISTRATION=true
REGISTRATION_APPROVAL_REQUIRED=false
AGENT_APPROVAL_REQUIRED=false
WEBSERVER_SIGN_PRIVATE_KEY_PATH=./keys/webserver_sign_private.pem
WEBSERVER_SIGN_PRIVATE_KEY_PASSPHRASE=
WEBSERVER_SIGN_PUBLIC_KEY_PATH=./keys/webserver_sign_public.pem
